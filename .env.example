# =========================================================================
# MindGuard Environment Configuration Template
# =========================================================================
# Copy this file to .env and configure the variables below.
# In a development environment, default values are provided.
# For production environments, ensure all credentials are secure.
# =========================================================================

# Application General Settings
PROJECT_NAME="MindGuard API"
VERSION="1.0.0"
ENVIRONMENT="development" # Set to "production" in live environments

# PostgreSQL Database Configuration
# These parameters configure both the db container and API connection settings.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mindguard_secure_pass
POSTGRES_DB=mindguard
POSTGRES_SERVER=db  # Use "localhost" if running outside of Docker
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# Security and JWT Tokens
# WARNING: Change SECRET_KEY to a secure 32-byte hexadecimal key in production!
# You can generate one using: openssl rand -hex 32
SECRET_KEY=very_secret_development_key_change_in_prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend Application Settings
# API base URL that the React application requests will target.
VITE_API_BASE_URL=http://localhost:8000/api/v1
